<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="ME_CompoundBase">
    <defName>ME_Compound_SickDrug</defName>
    <label>failed compound</label>
    <description>A dead-end compound. It does nothing useful and only makes the patient sick. Identified by testing.</description>
    <graphicData><texPath>Things/Item/Compound</texPath><graphicClass>Graphic_Single</graphicClass><color>(0.55,0.62,0.35)</color></graphicData>
    <ingestible><outcomeDoers><li Class="MedicalExperimentation.IngestionOutcomeDoer_Experimental"><hediffDef>ME_Hediff_ExpSickness</hediffDef><severity>0.7</severity></li></outcomeDoers></ingestible>
    <comps><li Class="MedicalExperimentation.CompProperties_MysteryDrug"><codePrefix>TX</codePrefix></li></comps>
  </ThingDef>

  <ThingDef ParentName="ME_CompoundBase">
    <defName>ME_Compound_LethalDrug</defName>
    <label>fatal compound</label>
    <description>A catastrophic compound. It kills whoever takes it. Identified by testing, at a cost.</description>
    <graphicData><texPath>Things/Item/Compound</texPath><graphicClass>Graphic_Single</graphicClass><color>(0.35,0.30,0.30)</color></graphicData>
    <ingestible><outcomeDoers><li Class="MedicalExperimentation.IngestionOutcomeDoer_Experimental"><hediffDef>ME_Hediff_LethalToxin</hediffDef></li></outcomeDoers></ingestible>
    <comps><li Class="MedicalExperimentation.CompProperties_MysteryDrug"><codePrefix>TX</codePrefix></li></comps>
  </ThingDef>

  <ThingDef ParentName="ME_CompoundBase">
    <defName>ME_Compound_RefinementSample</defName>
    <label>refinement sample</label>
    <description>A proof-of-concept dose. Testing it teaches the colony how to refine existing drugs into graded variants. Identified by testing.</description>
    <graphicData><texPath>Things/Item/Compound</texPath><graphicClass>Graphic_Single</graphicClass><color>(0.65,0.80,0.75)</color></graphicData>
    <ingestible><outcomeDoers><li Class="MedicalExperimentation.IngestionOutcomeDoer_Experimental"><hediffDef>ME_Hediff_RefinementSample</hediffDef></li></outcomeDoers></ingestible>
    <comps><li Class="MedicalExperimentation.CompProperties_MysteryDrug"><codePrefix>RX</codePrefix></li></comps>
  </ThingDef>

</Defs>
