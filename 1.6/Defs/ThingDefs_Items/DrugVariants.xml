<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ============================================================ -->
  <!-- DRUG VARIANTS                                                -->
  <!-- For each of 5 base drugs (GoJuice, WakeUp, Yayo, Flake,      -->
  <!-- SmokeleafJoint) three graded variants:                      -->
  <!--   Stable   = milder potency, safe (no chemical/addiction,    -->
  <!--              no overdose, no tolerance buildup).             -->
  <!--   Unstable = stronger potency, riskier (shares the base     -->
  <!--              chemical/tolerance, higher addiction+overdose). -->
  <!--   Perfect  = stronger potency AND safe (no chemical, no      -->
  <!--              overdose, no tolerance buildup).                -->
  <!-- All variants reuse the vanilla base drug texPath, tinted to  -->
  <!-- mark the grade. No CompMysteryDrug: these are known drugs.   -->
  <!-- ============================================================ -->

  <!-- ============================================================ -->
  <!-- GO-JUICE  (base severity 0.5, chemical GoJuice, listOrder 200)-->
  <!-- ============================================================ -->

  <ThingDef ParentName="MakeableDrugBase">
    <defName>ME_GoJuice_Stable</defName>
    <recipeMaker IsNull="True" />
    <label>stable go-juice</label>
    <description>A carefully buffered batch of go-juice. The dose is milder than a street batch, and the formula has been stabilized so it produces no tolerance, no addiction, and no overdose risk. A safe way to take the edge of go-juice into battle.</description>
    <graphicData>
      <texPath>Things/Item/Drug/GoJuice</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
      <color>(0.6,0.9,0.6)</color>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <WorkToMake>600</WorkToMake>
      <MarketValue>60</MarketValue>
      <Mass>0.1</Mass>
    </statBases>
    <techLevel>Spacer</techLevel>
    <tradeTags>
      <li>ME_Compound</li>
    </tradeTags>
    <ingestible>
      <joyKind>Chemical</joyKind>
      <joy>0.40</joy>
      <drugCategory>Hard</drugCategory>
      <foodType>Processed, Fluid</foodType>
      <baseIngestTicks>80</baseIngestTicks>
      <ingestSound>Ingest_Inject</ingestSound>
