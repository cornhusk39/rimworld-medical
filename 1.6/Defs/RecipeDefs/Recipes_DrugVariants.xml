  <!-- ============================================================ -->
  <!-- DRUG VARIANT RECIPES                                          -->
  <!-- All produced at the Experimentation Bench, gated behind      -->
  <!-- Experimental Pharmacology research. Each makes 4.            -->
  <!--   Stable   : 1 base + 1 MedicineIndustrial + 1 Neutroamine   -->
  <!--   Unstable : 1 base + 20 Chemfuel       + 1 Neutroamine      -->
  <!--   Perfect  : 1 base + 1 MedicineUltratech + 10 Neutroamine   -->
  <!-- ============================================================ -->

  <!-- ===================== GO-JUICE ===================== -->

  <RecipeDef>
    <defName>ME_Make_GoJuice_Stable</defName>
    <label>make stable go-juice</label>
    <description>Buffer go-juice into a milder, completely safe formula.</description>
    <jobString>Making stable go-juice.</jobString>
    <workAmount>1600</workAmount>
    <workSkill>Intellectual</workSkill>
    <workSpeedStat>DrugCookingSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Drug</soundWorking>
    <researchPrerequisite>ME_DrugRefinement</researchPrerequisite>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>GoJuice</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Neutroamine</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>GoJuice</li>
        <li>MedicineIndustrial</li>
        <li>Neutroamine</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <ME_GoJuice_Stable>4</ME_GoJuice_Stable>
    </products>
  </RecipeDef>

