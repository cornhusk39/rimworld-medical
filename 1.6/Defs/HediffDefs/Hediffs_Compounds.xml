<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>ME_AdverseReaction</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>adverse reaction</label>
    <description>A bad reaction to an experimental compound the patient's body cannot tolerate. Unpleasant and debilitating, but it passes.</description>
    <isBad>true</isBad>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.5</initialSeverity>
    <scenarioCanAdd>false</scenarioCanAdd>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-1.5</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <label>mild</label>
        <painOffset>0.10</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>serious</label>
        <painOffset>0.30</painOffset>
        <vomitMtbDays>0.2</vomitMtbDays>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.25</offset></li>
          <li><capacity>Moving</capacity><offset>-0.20</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>severe</label>
        <painOffset>0.50</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.40</offset></li>
          <li><capacity>Moving</capacity><offset>-0.35</offset></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ME_Hediff_AdrenalCatalyst</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>adrenal catalyst</label>
    <description>Heightened focus and reflexes from an adrenal catalyst dose.</description>
    <isBad>false</isBad>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>60000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>0.15</offset></li>
          <li><capacity>Moving</capacity><offset>0.20</offset></li>
        </capMods>
        <statOffsets>
          <WorkSpeedGlobal>0.15</WorkSpeedGlobal>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ME_Hediff_CoagulantSerum</defName>
    <hediffClass>HediffWithComps</hediffClass>
    <label>coagulant serum</label>
    <description>Improved clotting and immune response from a coagulant serum dose.</description>
    <isBad>false</isBad>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>30000</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <statOffsets>
          <ImmunityGainSpeed>0.10</ImmunityGainSpeed>
        </statOffsets>
        <capMods>
          <li><capacity>BloodPumping</capacity><offset>0.15</offset></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
